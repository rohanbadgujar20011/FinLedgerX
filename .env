# ============================================================
# FinLedgerX — Environment Variables
# ⚠️  NEVER commit this file to Git.
#     Copy to .env and fill in real values.
#     Add .env to .gitignore immediately.
# ============================================================

# ── App version ─────────────────────────────────────────────
APP_VERSION=latest

# ── Payments DB ─────────────────────────────────────────────
PAYMENTS_DB_NAME=payments_db
PAYMENTS_DB_USER=payments_user
PAYMENTS_DB_PASSWORD=payments_pass
PAYMENTS_DB_HOST_PORT=5432

# ── Ledger DB ────────────────────────────────────────────────
LEDGER_DB_NAME=ledger_db
LEDGER_DB_USER=ledger_user
LEDGER_DB_PASSWORD=ledger_pass
LEDGER_DB_HOST_PORT=5433

# ── Notifications DB ─────────────────────────────────────────
NOTIFICATIONS_DB_NAME=notifications_db
NOTIFICATIONS_DB_USER=notif_user
NOTIFICATIONS_DB_PASSWORD=notif_pass
NOTIFICATIONS_DB_HOST_PORT=5434

# ── Reconciliation DB ────────────────────────────────────────
RECONCILIATION_DB_NAME=reconciliation_db
RECONCILIATION_DB_USER=recon_user
RECONCILIATION_DB_PASSWORD=recon_pass
RECONCILIATION_DB_HOST_PORT=5435

# ── Redis ────────────────────────────────────────────────────
REDIS_PASSWORD=redis_pass
REDIS_HOST_PORT=6379

# ── Kafka ────────────────────────────────────────────────────
KAFKA_HOST_PORT=9092
SCHEMA_REGISTRY_HOST_PORT=8085

# ── Service Ports ────────────────────────────────────────────
PAYMENT_SERVICE_HOST_PORT=8081
LEDGER_SERVICE_HOST_PORT=8082
NOTIFICATION_SERVICE_HOST_PORT=8083
RECONCILIATION_SERVICE_HOST_PORT=8084

# ── UI & Gateway ─────────────────────────────────────────────
UI_HOST_PORT=3001

# ── Mail (dev only — MailHog) ────────────────────────────────
MAIL_HOST=mailhog
MAIL_PORT=1025

# ── Observability ────────────────────────────────────────────
PROMETHEUS_HOST_PORT=9090
GRAFANA_HOST_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=grafana_pass
